# ═══════════════════════════════════════════
# AUREX — Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════

# X Layer Configuration
XLAYER_RPC_URL=https://xlayerrpc.okx.com
XLAYER_CHAIN_ID=196

# Onchain OS API Key (Required)
# Get from: https://www.okx.com/web3/build/dev-hub
ONCHAIN_OS_API_KEY=your_onchain_os_api_key_here

# Agent 1 — Signal Price Agent Wallet
# Role: Generates price momentum signals via Onchain OS DEX API
SIGNAL_PRICE_PRIVATE_KEY=your_signal_price_private_key
SIGNAL_PRICE_ADDRESS=your_signal_price_address

# Agent 2 — Signal Flow Agent Wallet
# Role: Generates wallet flow signals via Onchain OS Wallet API
SIGNAL_FLOW_PRIVATE_KEY=your_signal_flow_private_key
SIGNAL_FLOW_ADDRESS=your_signal_flow_address

# Agent 3 — Allocator Agent Wallet
# Role: Credit scoring + capital allocation + trade execution
# Fund this wallet with OKB + USDT on X Layer
ALLOCATOR_PRIVATE_KEY=your_allocator_private_key
ALLOCATOR_ADDRESS=your_allocator_address

# X Layer Token Addresses
OKB_ADDRESS=0xe538905cf8410324e03a5a23c1c177a474d59b2
USDT_ADDRESS=0x1e4a5963abfd975d8c9021ce480b42188849d41d

# Optional: Wallets to monitor for flow signals
WATCH_WALLET_1=0x742d35Cc6634C0532925a3b844Bc454e4438f44e
WATCH_WALLET_2=0x8ba1f109551bD432803012645Ac136cc1836bA
WATCH_WALLET_3=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045

# Agent Configuration
LOOP_INTERVAL_MS=120000
TRADE_AMOUNT=5
SIGNAL_FEE_ETH=0.0001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001